{
  "name": "claude-web-ui",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "claude-web-ui": "cli.mjs",
    "cwu": "cli.mjs"
  },
  "files": [
    "cli.mjs",
    "server/dist/",
    "web/dist/"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter ./server --filter ./web dev",
    "dev:server": "pnpm --filter ./server dev",
    "dev:web": "pnpm --filter ./web dev",
    "build": "pnpm --filter ./web build && pnpm --filter ./server build",
    "start": "pnpm --filter ./server start",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "packageManager": "pnpm@10.31.0",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.216",
    "@fastify/static": "^8.0.4",
    "fastify": "^5.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript-eslint": "^8.65.0"
  }
}
