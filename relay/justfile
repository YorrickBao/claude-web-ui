# Claude WebUI 中转服务构建脚本（justfile）
#
# 用法：
#   just build              # 编译当前平台
#   just build-all          # 交叉编译全部 5 个平台（对齐 CI）
#   just build-linux        # 交叉编译 Linux amd64（最常见 VPS）
#   just build-linux-arm64  # 交叉编译 Linux arm64（ARM VPS）
#   just build-darwin-amd64 # 交叉编译 macOS amd64（Intel Mac）
#   just build-darwin-arm64 # 交叉编译 macOS arm64（Apple Silicon）
#   just build-windows-amd64 # 交叉编译 Windows amd64
#   just run                # 本地直接运行
#   just vet                # 静态检查
#   just fmt                # 格式化
#   just clean              # 清理产物

BIN     := "claude-web-ui-relay"
DIST    := "dist"
LDFLAGS := "-s -w"
GOFLAGS := "-trimpath"
LISTEN  := "127.0.0.1:8787"

# 编译当前平台
build:
    mkdir -p {{DIST}}
    go build {{GOFLAGS}} -ldflags "{{LDFLAGS}}" -o {{DIST}}/{{BIN}} .

# 交叉编译 Linux amd64（最常见 VPS）
build-linux:
    mkdir -p {{DIST}}
    GOOS=linux GOARCH=amd64 CGO_ENABLED=0 go build {{GOFLAGS}} -ldflags "{{LDFLAGS}}" -o {{DIST}}/{{BIN}}-linux-amd64 .

# 交叉编译 Linux arm64（ARM VPS）
build-linux-arm64:
    mkdir -p {{DIST}}
    GOOS=linux GOARCH=arm64 CGO_ENABLED=0 go build {{GOFLAGS}} -ldflags "{{LDFLAGS}}" -o {{DIST}}/{{BIN}}-linux-arm64 .

# 交叉编译 macOS amd64（Intel Mac）
build-darwin-amd64:
    mkdir -p {{DIST}}
    GOOS=darwin GOARCH=amd64 CGO_ENABLED=0 go build {{GOFLAGS}} -ldflags "{{LDFLAGS}}" -o {{DIST}}/{{BIN}}-darwin-amd64 .

# 交叉编译 macOS arm64（Apple Silicon）
build-darwin-arm64:
    mkdir -p {{DIST}}
    GOOS=darwin GOARCH=arm64 CGO_ENABLED=0 go build {{GOFLAGS}} -ldflags "{{LDFLAGS}}" -o {{DIST}}/{{BIN}}-darwin-arm64 .

# 交叉编译 Windows amd64
build-windows-amd64:
    mkdir -p {{DIST}}
    GOOS=windows GOARCH=amd64 CGO_ENABLED=0 go build {{GOFLAGS}} -ldflags "{{LDFLAGS}}" -o {{DIST}}/{{BIN}}-windows-amd64.exe .

# 交叉编译全部 5 个平台（对齐 .github/workflows/build-relay.yml）
build-all: build-linux build-linux-arm64 build-darwin-amd64 build-darwin-arm64 build-windows-amd64
    @echo "✓ 全部平台构建完成，产物在 {{DIST}}/"

# 本地直接运行（不落产物）
run:
    go run . --listen {{LISTEN}}

# 静态检查
vet:
    go vet ./...

# 格式化
fmt:
    gofmt -s -w .

# 清理产物
clean:
    rm -rf {{DIST}}
